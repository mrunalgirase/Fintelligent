# Fintelligent Environment Variables Example
# Copy this to .env and change the values
SECRET_KEY=generate-a-long-random-string-here
FLASK_DEBUG=False
SQLALCHEMY_DATABASE_URI=sqlite:///fintelligent.db

# AI Coach — Groq cloud is recommended (no local CPU lag). Uses same key as receipt scanning.
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# AI Coach — local Ollama fallback (only used when GROQ_API_KEY is not set)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=400
