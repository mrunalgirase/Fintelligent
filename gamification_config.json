    "challenges": [
        {
            "id": "chal_001",
            "title": "₹100/Day Challenge",
            "description": "Limit your discretionary daily spending to just ₹100.",
            "duration_days": 1,
            "recurrence": "Weekly",
            "input_type": "boolean",
            "rules": [
                "Groceries and bills excluded",
                "Only counts discretionary spend (food, entertainment, travel)"
            ],
            "success_condition": "spend_discretionary <= 100",
            "reward": {
                "xp": 50,
                "badge_id": null,
                "streak_boost": 1
            },
            "audience": "Students"
        },
        {
            "id": "chal_002",
            "title": "No Zomato Week",
            "description": "A full week of home-cooked meals only.",
            "duration_days": 7,
            "recurrence": "Monthly",
            "input_type": "none",
            "rules": [
                "No transactions on Zomato, Swiggy, or similar apps",
                "Dining out allowed max 1 time for social obligation"
            ],
            "success_condition": "food_app_spend == 0",
            "reward": {
                "xp": 200,
                "badge_id": "badge_homechef",
                "streak_boost": 0
            },
            "audience": "All"
        },
        {
            "id": "chal_004",
            "title": "Market Bargain Hunter",
            "description": "Log your savings from street shopping negotiations.",
            "duration_days": 30,
            "recurrence": "Monthly",
            "input_type": "saving_input",
            "input_label": "Enter Amount Saved (₹)",
            "input_placeholder": "e.g., Asked 500, Paid 400 = 100",
            "rules": [
                "Enter the difference between asking price and paid price",
                "Be honest!"
            ],
            "success_condition": "cumulative_savings >= 500",
            "reward": {
                "xp": 100,
                "badge_id": "badge_006",
                "streak_boost": 0
            },
            "audience": "All"
        },
        {
            "id": "chal_005",
            "title": "Public Transport Hero",
            "description": "Saved by taking Bus/Metro instead of Cab/Auto?",
            "duration_days": 30,
            "recurrence": "Monthly",
            "input_type": "saving_input",
            "input_label": "Enter Cab Fare Saved (₹)",
            "input_placeholder": "e.g., Cab 300 - Metro 40 = 260",
            "rules": [
                "Calculate: Cab Fare (Estimated) - Actual Ticket Cost",
                "Log it every time you commute"
            ],
            "success_condition": "cumulative_savings >= 1000",
            "reward": {
                "xp": 150,
                "badge_id": "badge_007",
                "streak_boost": 0
            },
            "audience": "Commuters"
        },
        {
            "id": "chal_006",
            "title": "Library Regular",
