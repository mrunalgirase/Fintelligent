flowchart TD
    %% =========================================
    %% DFD LEVEL 3 – SPENDING ANALYTICS & RECOMMENDATION DETAIL
    %% Focus on /analytics + regression & clustering
    %% =========================================

    %% External Entity
    User["E1: User"]

    %% Top-Level Process
    P3["P3: Spending Analytics & Recommendations<br/>(/analytics, recommendation routes)"]

    %% Decomposed Subprocesses
    P3_1["P3.1: Upload & Parse CSV"]
    P3_2["P3.2: Clean & Enrich Transactions"]
    P3_3["P3.3: Aggregate Metrics<br/>(totals, monthly trend)"]
    P3_4["P3.4: Build Category Feature Matrix"]
    P3_5["P3.5: Cluster Categories<br/>(StandardScaler + KMeans + PCA)"]
    P3_6["P3.6: Compute Health Score & Velocity Label"]
    P3_7["P3.7: Budget Forecast & Overspending Detection"]
    P3_8["P3.8: Generate Cluster Insights<br/>(top categories, merchants, payment mix)"]
    P3_9["P3.9: Build Dashboard JSON<br/>(charts, insights, alerts)"]
    P3_10["P3.10: Train Regression from Tax History<br/>(get_regression_recommendation)"]
    P3_11["P3.11: Predict Recommended Allocations<br/>(80C, 80D, housing)"]
    
    %% Data Stores
    D1["D1: User & Gamification DB<br/>(user id, monthly budget)"]
    D2["D2: Tax History CSV<br/>(user_tax_history.csv)"]
    D3["D3: Uploaded CSV (raw)"]
    D4["D4: Processed Analytics Snapshot<br/>(cached dashboard state)"]

    %% External Systems (optional inputs)
    AISvc["E2: AI Service / LLM Tips<br/>(optional future integration)"]

    %% USER ↔ ENTRY
    User -->|"Upload CSV file"| P3_1
    P3_1 -->|"Raw CSV stored (user, filename)"| D3
    D3 -->|"Raw rows"| P3_2

    %% CLEAN & ENRICH
    P3_2 -->|"Typed transactions<br/>(date, category, amount, merchant, payment_method)"| P3_3

    %% AGGREGATIONS
    P3_3 -->|"total_spent, category_totals,<br/>monthly series"| P3_4

    %% FEATURE MATRIX FOR CLUSTERING
    P3_4 -->|"Per-category features<br/>(mean, sum, count)"| P3_5

    %% CLUSTERING
    P3_5 -->|"Cluster labels per category<br/>+ PCA points"| P3_8

    %% HEALTH SCORE & VELOCITY
    P3_3 -->|"Totals & averages"| P3_6
    P3_6 -->|"Score + velocity label"| P3_9

    %% BUDGET & OVESPENDING
    User -->|"Monthly budget (profile)"| D1
    D1 -->|"Budget limit for user"| P3_7

    P3_2 -->|"This month transactions"| P3_7
    P3_7 -->|"Forecast vs limit,<br/>overspending flags"| P3_9

    %% CLUSTER INSIGHTS
    P3_5 -->|"Cluster assignments<br/>(cluster_id per row)"| P3_8
    P3_2 -->|"Enriched transactions<br/>with categories & methods"| P3_8

    P3_8 -->|"Per-cluster stats:<br/>count, avg, total, frequency_score,<br/>spend_ratio, top categories, merchants,<br/>payment_method mix"| P3_9

    %% REGRESSION RECOMMENDATION
    User -->|"Current income & housing profile"| P3_11
    D2 -->|"Historical tax rows"| P3_10
    P3_10 -->|"Fitted LinearRegression models<br/>per target (80C, 80D, housing)"| P3_11
    P3_11 -->|"Recommended numeric allocations"| P3_9

    %% DASHBOARD BUILD
    P3_9 -->|"Dashboard JSON:<br/>financial_category, category_color, icon,<br/>total_spent, category_distribution,<br/>monthly_trend, budget, health_score,<br/>pca_points, cluster_details,<br/>insights, overspending_areas"| D4
    D4 -->|"Dashboard JSON"| User

    %% OPTIONAL: AI SERVICE HOOK
    P3_9 -->|"Key metrics (top overspend,<br/>score, clusters)"| AISvc
    AISvc -->|"Context-aware coaching tips"| User

