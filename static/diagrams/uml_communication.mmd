graph TB
    subgraph "Communication Diagram - Tax Calculation"
        User1[User]
        Browser1[Web Browser]
        App1[Flask App]
        TaxRoute1[TaxRoutes]
        TaxCalc1[TaxCalculator]
        CSV1[CSVManager]
        DB1[Database]
        
        User1 <-->|1: Request Tax Calc| Browser1
        Browser1 <-->|2: POST /tax/calculate| App1
        App1 <-->|3: Route Request| TaxRoute1
        TaxRoute1 <-->|4: Calculate Tax| TaxCalc1
        TaxRoute1 <-->|5: Save Data| CSV1
        TaxRoute1 <-->|6: Get User| DB1
        TaxCalc1 <-->|7: Return Results| TaxRoute1
        CSV1 <-->|8: Write CSV| CSV1
        TaxRoute1 <-->|9: JSON Response| Browser1
        Browser1 <-->|10: Display Results| User1
    end
    
    subgraph "Communication Diagram - Stock Analysis"
        User2[User]
        Browser2[Web Browser]
        App2[Flask App]
        StockRoute1[StockRoutes]
        StockAnalyzer1[StockAnalyzer]
        ClusterEngine1[ClusteringEngine]
        API1[Stock API]
        
        User2 <-->|1: Request Analysis| Browser2
        Browser2 <-->|2: GET /get_clusters| App2
        App2 <-->|3: Route Request| StockRoute1
        StockRoute1 <-->|4: Fetch Data| StockAnalyzer1
