        RecRoute1 <-->|15: Render Page| Browser3
        Browser3 <-->|16: Display Results| User3
    end
    
    subgraph "Communication Diagram - Authentication"
        User4[User]
        Browser4[Web Browser]
        App4[Flask App]
        AuthRoute1[AuthRoutes]
        UserModel1[User Model]
        DB2[Database]
        Session1[Session Manager]
        
        User4 <-->|1: Login Request| Browser4
        Browser4 <-->|2: POST /login| App4
        App4 <-->|3: Route Request| AuthRoute1
        AuthRoute1 <-->|4: Get User| UserModel1
        UserModel1 <-->|5: Query User| DB2
        DB2 <-->|6: Return User| UserModel1
        UserModel1 <-->|7: Check Password| UserModel1
        UserModel1 <-->|8: Validation Result| AuthRoute1
        AuthRoute1 <-->|9: Create Session| Session1
        Session1 <-->|10: Session Created| AuthRoute1
        AuthRoute1 <-->|11: Redirect| Browser4
        Browser4 <-->|12: Show Dashboard| User4
