        StockAnalyzer1 <-->|10: Analysis Results| StockRoute1
        StockRoute1 <-->|11: JSON Response| Browser2
        Browser2 <-->|12: Display Analysis| User2
    end
    
    subgraph "Communication Diagram - Expenditure Analysis"
        User3[User]
        Browser3[Web Browser]
        App3[Flask App]
        RecRoute1[RecommendationRoutes]
        ExpProcessor1[ExpenditureProcessor]
        ClusterEngine2[ClusteringEngine]
        RecGen1[RecommendationGenerator]
        CSV2[CSVManager]
        
        User3 <-->|1: Upload CSV| Browser3
        Browser3 <-->|2: POST /upload| App3
        App3 <-->|3: Route Request| RecRoute1
        RecRoute1 <-->|4: Validate File| ExpProcessor1
        ExpProcessor1 <-->|5: Validation Result| RecRoute1
        RecRoute1 <-->|6: Process Data| ExpProcessor1
        ExpProcessor1 <-->|7: Aggregate Data| ExpProcessor1
        ExpProcessor1 <-->|8: Processed Data| RecRoute1
