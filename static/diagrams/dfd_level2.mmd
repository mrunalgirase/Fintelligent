flowchart TD
    %% =========================================
    %% DFD LEVEL 2 – CORE FLOWS (TAX, ANALYTICS, STOCK, AI COACH)
    %% =========================================

    %% External Entity
    User["E1: User"]

    %% Processes
    P1["P1: Auth & Dashboard<br/>(main, auth blueprints)"]
    P2["P2: Tax Calculation & Comparison<br/>(tax routes)"]
    P3["P3: Spending Analytics & Clustering<br/>(recommendation /analytics)"]
    P4["P4: Stock Risk Clustering<br/>(stocks /get_clusters)"]
    P5["P5: AI Financial Coach<br/>(ai_service FastAPI + ai_coach blueprint)"]
    P6["P6: Gamification Engine<br/>(gamification routes + config)"]
    
    %% Data Stores
    D1["D1: User & Gamification DB<br/>(SQLite fintelligent.db)"]
    D2["D2: Tax History CSV<br/>(user_tax_history.csv)"]
    D3["D3: Uploaded Spend CSVs<br/>(user transaction files)"]
    D4["D4: Gamification Config<br/>(gamification_config.json)"]

    %% External Systems
    StockAPI["E2: Stock Market Data<br/>(yfinance)"]
    Ollama["E3: Ollama LLM Server<br/>(llama3)"]

    %% USER <-> AUTH & DASHBOARD
    User -->|"Credentials, signup data"| P1
    P1 -->|"Auth status, dashboard view"| User

    P1 -->|"Create/Update user,<br/>XP, levels, settings"| D1
    D1 -->|"User profile, XP, budgets"| P1

    %% TAX FLOW
    User -->|"Income + deductions input"| P2
    P2 -->|"Tax breakdown,<br/>regime recommendation"| User

    P2 -->|"Persist raw tax entry<br/>(user_id, income, sections)"| D2
    D2 -->|"Historical tax rows<br/>(training data)"| P2

    P2 -->|"Read user profile,<br/>basic settings"| D1
    D1 -->|"User meta (e.g., regime preference)"| P2

    P2 -->|"Tax savings, TDS,<br/>effective rates"| P6

    %% SPENDING ANALYTICS FLOW
    User -->|"Upload transactions CSV"| P3
    P3 -->|"Normalized CSV stored<br/>with user context"| D3
    D3 -->|"Rows: date, category,<br/>amount, merchant"| P3

    P3 -->|"Analytics dashboard data<br/>(totals, trends, clusters)"| User

    P3 -->|"Update user budget metrics,<br/>health score, overspend flags"| D1
    D1 -->|"User budget limit,<br/>past health scores"| P3

    P3 -->|"Spending category clusters,<br/>overspending signals"| P6

    %% STOCK CLUSTERING FLOW
    User -->|"Stock symbol (e.g., INFY)"| P4
    P4 -->|"OHLCV request for 1y data"| StockAPI
    StockAPI -->|"Daily OHLCV series"| P4

    P4 -->|"Clustered 60-day timeseries<br/>(date, close, volatility, cluster)"| User

    P4 -->|"Risk profile & cluster summary"| P6

    %% AI COACH FLOW
    User -->|"Request for financial literacy tips"| P5
    P3 -->|"Aggregated spending behavior<br/>(optional context)"| P5

    P5 -->|"System + user prompt,<br/>JSON mode request"| Ollama
    Ollama -->|"JSON guide: sip, emergency fund,<br/>upi, credit card, emi"| P5

    P5 -->|"Coach tips, explanations,<br/>habits to UI"| User

    P5 -->|"Coach usage events,<br/>learned topics"| P6

    %% GAMIFICATION FLOW
    P6 -->|"Read badge rules,<br/>challenges, XP mapping"| D4
    D4 -->|"Gamification config JSON"| P6

    P6 -->|"Update XP, streaks,<br/>completed challenges"| D1
    D1 -->|"Current XP, badge state,<br/>challenge progress"| P6

    P6 -->|"Gamified feedback, badges,<br/>alerts, friendly messages"| User

